{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName":     { "value": "${AZURE_ENV_NAME}" },
    "location":            { "value": "${AZURE_LOCATION}" },
    "foundryAccountName":  { "value": "${AZURE_FOUNDRY_ACCOUNT_NAME}" },
    "azureOpenAiEndpoint": { "value": "${AZURE_OPENAI_ENDPOINT}" },
    "backendImage":        { "value": "${SERVICE_BACKEND_IMAGE_NAME=mcr.microsoft.com/k8se/quickstart:latest}" },
    "frontendImage":       { "value": "${SERVICE_FRONTEND_IMAGE_NAME=mcr.microsoft.com/k8se/quickstart:latest}" }
  }
}

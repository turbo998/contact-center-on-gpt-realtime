# ====== Azure OpenAI / Foundry ======
AZURE_OPENAI_ENDPOINT=https://your-foundry.openai.azure.com
AZURE_OPENAI_API_KEY=replace-me-local-only
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment names (in Azure AI Foundry)
DEPLOYMENT_TRANSLATE=gpt-realtime-translate
DEPLOYMENT_WHISPER=gpt-realtime-whisper
DEPLOYMENT_ASSISTANT=gpt-realtime-2

# ====== App ======
APP_ENV=development                # development | production
LOG_LEVEL=INFO
MAX_CALL_DURATION_SEC=900          # 15 min hard cap
AUDIT_DIR=./audit                  # local audit jsonl dir; on Azure mounted from Blob

# ====== Frontend ======
NEXT_PUBLIC_BACKEND_WS_BASE=ws://localhost:8000
NEXT_PUBLIC_BACKEND_HTTP_BASE=http://localhost:8000

# ====== Azure (azd up will populate these) ======
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
